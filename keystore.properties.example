
# ================================================================
# KEYSTORE PROPERTIES — copia este archivo como "keystore.properties"
# NO subas keystore.properties ni el .jks al repositorio
# ================================================================

# Ruta al archivo .jks (relativa a la raíz del proyecto)
storeFile=keystore/daymood-release.jks

# Contraseña del keystore (la que pusiste al crearlo)
storePassword=TU_STORE_PASSWORD

# Alias de la llave (el que pusiste al crearlo)
keyAlias=daymood-key

# Contraseña de la llave
keyPassword=TU_KEY_PASSWORD
